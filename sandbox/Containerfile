FROM node:24.14.0-bookworm

# Common dev tools
RUN apt-get update && apt-get install -y \
    git \
    curl \
    jq \
    openssh-client \
    && rm -rf /var/lib/apt/lists/*

# Install GitHub CLI
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" | tee /etc/apt/sources.list.d/github-cli.list > /dev/null \
    && apt-get update && apt-get install -y gh \
    && rm -rf /var/lib/apt/lists/*

# Install Claude Code CLI and OpenCode (pinned versions)
RUN npm install -g @anthropic-ai/claude-code@2.1.77 opencode-ai@1.2.27

# Install Playwright Chromium OS dependencies (browsers installed at runtime from project version)
RUN npx playwright install-deps chromium

# Bundle settings and entrypoint
COPY claude-settings.json opencode-settings.json /etc/ai-sandbox/
COPY entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

# Create a non-root user matching typical host UID
ARG USER_UID=1000
ARG USER_GID=1000
RUN groupmod -g ${USER_GID} node && usermod -u ${USER_UID} -g ${USER_GID} node
RUN mkdir -p /home/node/.claude /home/node/.config/opencode /home/node/.local/share/opencode /home/node/.local/state/opencode /home/node/.cache/opencode && chown -R node:node /home/node

USER node
WORKDIR /workspace

ENTRYPOINT ["entrypoint.sh"]
CMD ["shell"]
